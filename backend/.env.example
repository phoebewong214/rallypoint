# Copy to .env and fill in real values
FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///rallypoint.db
# When ready for Postgres:
# DATABASE_URL=postgresql://user:pass@localhost:5432/rallypoint

# CORS — frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional — OpenAI for AI match reasoning. Leave blank for heuristic fallback.
OPENAI_API_KEY=
