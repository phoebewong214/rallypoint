# Copy to .env and fill in real values
FLASK_ENV=development
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///rallypoint.db
# When ready for Postgres:
# DATABASE_URL=postgresql://user:pass@localhost:5432/rallypoint

# CORS — frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional — OpenAI for AI match reasoning. Leave blank for heuristic fallback.
OPENAI_API_KEY=

# Public URL of the SPA — used to build links inside emails.
APP_BASE_URL=http://localhost:5173

# SMTP — transactional email (verification + password reset).
# Leave SMTP_HOST blank in dev: emails are logged to the backend console
# (look for "[email:dev]") instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=RallyPoint <no-reply@rallypoint.app>
SMTP_USE_TLS=true
# Token lifetimes (minutes)
VERIFY_TOKEN_TTL_MIN=1440
RESET_TOKEN_TTL_MIN=60

# Auth cookies. The JWT is stored in an httpOnly cookie; a readable CSRF
# cookie guards unsafe requests (double-submit).
# In dev (http://localhost) leave COOKIE_SECURE=false and SameSite=Lax.
# In prod set COOKIE_SECURE=true; use SameSite=None only for cross-site SPAs.
AUTH_COOKIE_NAME=rp_session
CSRF_COOKIE_NAME=rp_csrf
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# COOKIE_DOMAIN=.rallypoint.app
AUTH_COOKIE_MAX_AGE=604800
